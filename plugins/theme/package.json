{
  "name": "paperclip-theme",
  "version": "0.2.0",
  "description": "In-app theme customizer for Paperclip with live preview, presets, and shareable configs",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "build": "tsc && node ./scripts/build-ui.mjs",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "2026.325.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "author": "Khaleeq Fisher <Khaleeqfisher2@gmail.com>",
  "license": "MIT",
  "keywords": [
    "paperclip",
    "plugin",
    "theme",
    "customizer",
    "dark-mode",
    "design-tokens"
  ]
}
